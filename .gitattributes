# Auto-detect text files and normalize to LF on commit
* text=auto

# Python files
*.py text eol=lf
*.pyi text eol=lf

# Documentation
*.md text eol=lf
*.txt text eol=lf
*.rst text eol=lf

# Config files
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.json text eol=lf
*.cfg text eol=lf
requirements*.txt text eol=lf

# Scripts
*.sh text eol=lf
*.bat text eol=crlf

# Binary
*.png binary
*.jpg binary
*.pdf binary
*.h5 binary
*.nc binary
